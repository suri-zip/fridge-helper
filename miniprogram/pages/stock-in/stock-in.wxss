.form-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F2937;
}

.input,
.picker {
  background: #F8FAFC;
  border-radius: 24rpx;
  padding: 22rpx 26rpx;
  font-size: 28rpx;
  color: #1F2937;
}

.save-btn {
  margin-top: 20rpx;
  background: #A7D8FF;
  color: #1F2937;
  border-radius: 999rpx;
  font-weight: 700;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.square-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #A7D8FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
}

.quantity-input {
  flex: 1;
  height: 80rpx;
  background: #F8FAFC;
  border-radius: 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emoji-item {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border: 4rpx solid transparent;
}

.emoji-item.selected {
  background: #EAF5FF;
  border-color: #A7D8FF;
}