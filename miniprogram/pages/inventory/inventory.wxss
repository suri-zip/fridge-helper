.search {

  background: white;

  border-radius: 999rpx;

  padding: 20rpx 30rpx;

  margin-bottom: 20rpx;

}

.mode-bar {

  display: flex;

  gap: 16rpx;

  margin-bottom: 20rpx;

}

.mode-chip {

  flex: 1;

  text-align: center;

  padding: 16rpx 20rpx;

  background: white;

  border-radius: 999rpx;

}

.area-bar {

  white-space: nowrap;

  margin-bottom: 20rpx;

}

.area-chip {

  display: inline-block;

  padding: 14rpx 26rpx;

  margin-right: 18rpx;

  background: white;

  border-radius: 999rpx;

}

.category-bar {

  white-space: nowrap;

  margin-bottom: 30rpx;

}

.category {

  display: inline-block;

  padding: 14rpx 26rpx;

  margin-right: 18rpx;

  background: white;

  border-radius: 999rpx;

}

.active {

  background: #A7D8FF;

}