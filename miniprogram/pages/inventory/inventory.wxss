.search-box {
  height: 84rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.05);
}

.search-icon {
  color: #9ca3af;
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  color: #1f2937;
}

.clear-search {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef2f6;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.mode-bar {

  display: flex;

  gap: 16rpx;

  margin-bottom: 20rpx;

}

.mode-chip {

  flex: 1;

  text-align: center;

  padding: 16rpx 20rpx;

  background: white;

  border-radius: 999rpx;

}

.category-bar {

  white-space: nowrap;

  margin-bottom: 30rpx;

}

.category {

  display: inline-block;

  padding: 14rpx 26rpx;

  margin-right: 18rpx;

  background: white;

  border-radius: 999rpx;

}

.active {

  background: #A7D8FF;

}
.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: #6b7280;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-image {
  width: 140rpx;
  height: 140rpx;
  display: block;
  margin: 0 auto;
}

.hungry-icon {
  width: 120rpx;
  height: 120rpx;
  display: block;
  margin: 0 auto;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #374151;
}

.empty-text {
  margin-top: 8rpx;
  font-size: 26rpx;
}