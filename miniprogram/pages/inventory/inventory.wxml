<view class="container">

<view class="section-title">冰箱区域</view>

<scroll-view
    scroll-x
    class="area-bar"
>

    <block
        wx:for="{{fridgeAreas}}"
        wx:key="id"
    >

        <view
            class="area-chip {{activeAreaId==item.id?'active':''}}"
            data-area-id="{{item.id}}"
            data-area-type="{{item.type}}"
            bindtap="setArea"
        >
            {{item.name}} · {{item.count}}
        </view>

    </block>

</scroll-view>

<input
    class="search"
    placeholder="搜索食材..."
    bindinput="onSearch"
/>

<scroll-view
    scroll-x
    class="category-bar"
>

    <block
        wx:for="{{categories}}"
        wx:key="*this"
    >

        <view
            class="category {{currentCategory==item?'active':''}}"
            data-category="{{item}}"
            bindtap="changeCategory"
        >
            {{item}}
        </view>

    </block>

</scroll-view>

<view class="food-list">

    <block
        wx:for="{{displayList}}"
        wx:key="id"
    >
        <view
            data-id="{{item.id}}"
            bindtap="onFoodTap"

        >
            <food-card item="{{item}}" />
        </view>
    </block>
</view>
</view>