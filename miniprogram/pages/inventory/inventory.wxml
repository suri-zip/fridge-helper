<view class="container">
    <view class="section-title">库存分类</view>

    <view class="mode-bar">
        <view
            class="mode-chip {{categoryMode=='area'?'active':''}}"
            data-mode="area"
            bindtap="switchCategoryMode"
        >
            按冰箱区域分类
        </view>

        <view
            class="mode-chip {{categoryMode=='food'?'active':''}}"
            data-mode="food"
            bindtap="switchCategoryMode"
        >
            按食物种类分类
        </view>
    </view>

    <scroll-view
        scroll-x
        class="category-bar"
    >
        <block
            wx:for="{{categories}}"
            wx:key="value"
        >
            <view
                class="category {{currentCategory==item.value?'active':''}}"
                data-category="{{item.value}}"
                bindtap="changeCategory"
            >
                {{item.label}}{{categoryMode=='area' && item.value!='all' ? ' · ' + item.count : ''}}
            </view>
        </block>
    </scroll-view>

    <view class="search-box">
  <text class="search-icon">⌕</text>

  <input
    class="search-input"
    placeholder="搜索食材"
    value="{{keyword}}"
    bindinput="onSearch"
    confirm-type="search"
  />

  <view
    wx:if="{{keyword}}"
    class="clear-search"
    bindtap="clearSearch"
  >
    ×
  </view>
</view>

    <view class="food-list">
        <block
            wx:for="{{displayList}}"
            wx:key="id"
        >
            <view
                data-id="{{item.id}}"
                bindtap="onFoodTap"
            >
                <food-card item="{{item}}" />
            </view>
        </block>
    </view>

        <view wx:if="{{!loading && inventory.length === 0}}" class="empty-state">
            <image class="hungry-icon" src="/assets/hungry.png" mode="aspectFit"></image>
            <view class="empty-title">还没有食材</view>
            <view class="empty-text">先去记录一些新食材吧</view>
        </view>

        <view wx:elif="{{!loading && keyword && displayList.length === 0}}" class="empty-state">
            <image class="empty-image" src="/assets/cannot_find.png" mode="aspectFit"></image>
            <view class="empty-title">没有找到相关食材</view>
            <view class="empty-text">换个关键词试试吧</view>
        </view>

        <view wx:elif="{{!loading && !keyword && displayList.length === 0}}" class="empty-state">
            <view class="empty-icon">📦</view>
            <view class="empty-title">当前分类没有食材</view>
            <view class="empty-text">试试切换分类看看</view>
        </view>
</view>