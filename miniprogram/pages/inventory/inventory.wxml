<view class="container">
    <view class="section-title">库存分类</view>

    <view class="mode-bar">
        <view
            class="mode-chip {{categoryMode=='area'?'active':''}}"
            data-mode="area"
            bindtap="switchCategoryMode"
        >
            按冰箱区域分类
        </view>

        <view
            class="mode-chip {{categoryMode=='food'?'active':''}}"
            data-mode="food"
            bindtap="switchCategoryMode"
        >
            按食物种类分类
        </view>
    </view>

    <scroll-view
        scroll-x
        class="category-bar"
    >
        <block
            wx:for="{{categories}}"
            wx:key="value"
        >
            <view
                class="category {{currentCategory==item.value?'active':''}}"
                data-category="{{item.value}}"
                bindtap="changeCategory"
            >
                {{item.label}}{{categoryMode=='area' && item.value!='all' ? ' · ' + item.count : ''}}
            </view>
        </block>
    </scroll-view>

    <input
        class="search"
        placeholder="搜索食材..."
        bindinput="onSearch"
    />

    <view class="food-list">
        <block
            wx:for="{{displayList}}"
            wx:key="id"
        >
            <view
                data-id="{{item.id}}"
                bindtap="onFoodTap"
            >
                <food-card item="{{item}}" />
            </view>
        </block>
    </view>
</view>