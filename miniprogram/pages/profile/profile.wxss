.profile-page {
	padding-bottom: 36rpx;
}

.hero {
	background: linear-gradient(135deg, #d7f0ff 0%, #a7d8ff 48%, #8ccdf5 100%);
	overflow: hidden;
}

.hero-top {
	display: flex;
	justify-content: space-between;
	gap: 24rpx;
	align-items: flex-start;
}

.hero-label {
	font-size: 24rpx;
	font-weight: 700;
	color: #145b88;
	letter-spacing: 2rpx;
}

.hero-title {
	margin-top: 12rpx;
	font-size: 42rpx;
	font-weight: 800;
	color: #0f3551;
}

.hero-sub {
	margin-top: 12rpx;
	font-size: 26rpx;
	line-height: 1.6;
	color: rgba(15, 53, 81, 0.82);
}

.hero-badge {
	min-width: 120rpx;
	padding: 16rpx 20rpx;
	border-radius: 999rpx;
	background: rgba(255, 255, 255, 0.52);
	color: #0f3551;
	font-size: 28rpx;
	font-weight: 700;
	text-align: center;
}

.invite-panel {
	margin-top: 28rpx;
	padding: 24rpx;
	border-radius: 28rpx;
	background: rgba(255, 255, 255, 0.58);
	backdrop-filter: blur(12px);
}

.invite-label {
	font-size: 24rpx;
	font-weight: 700;
	color: #145b88;
}

.invite-code {
	margin-top: 12rpx;
	font-size: 40rpx;
	font-weight: 800;
	letter-spacing: 4rpx;
	color: #10344d;
}

.invite-code.large {
	font-size: 44rpx;
	letter-spacing: 6rpx;
}

.invite-actions {
	margin-top: 20rpx;
	display: flex;
	gap: 18rpx;
	flex-wrap: wrap;
}

.action-btn {
	margin: 0;
	border-radius: 999rpx;
	font-size: 26rpx;
	line-height: 1;
	padding: 20rpx 28rpx;
}

.action-btn::after {
	border: none;
}

.action-btn.primary {
	background: #0f3551;
	color: #ffffff;
}

.action-btn.ghost {
	background: rgba(255, 255, 255, 0.7);
	color: #0f3551;
}

.action-btn.full {
	width: 100%;
}

.member-card {
	padding-top: 12rpx;
	padding-bottom: 12rpx;
}

.member-item {
	display: flex;
	align-items: center;
	gap: 20rpx;
	padding: 22rpx 0;
}

.member-item + .member-item {
	border-top: 1rpx solid #edf2f7;
}

.member-avatar {
	width: 84rpx;
	height: 84rpx;
	border-radius: 24rpx;
	background: #f1f7fb;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 44rpx;
	flex-shrink: 0;
}

.member-meta {
	flex: 1;
	min-width: 0;
}

.member-name-row {
	display: flex;
	align-items: center;
	gap: 16rpx;
	flex-wrap: wrap;
}

.member-name {
	font-size: 30rpx;
	font-weight: 700;
	color: #1f2937;
}

.member-role {
	padding: 8rpx 16rpx;
	border-radius: 999rpx;
	background: #e8f4fb;
	color: #2b6a92;
	font-size: 22rpx;
}

.member-status {
	margin-top: 6rpx;
	font-size: 24rpx;
	color: #6b7280;
}

.invite-card {
	background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
}

.invite-tip {
	font-size: 26rpx;
	line-height: 1.7;
	color: #4b5563;
}

.area-form-card {
	margin-bottom: 24rpx;
}

.area-form-actions {
	margin-top: 28rpx;
}

.area-form-actions.two-btns {
	display: flex;
	gap: 16rpx;
}

.section-subtitle {
	font-size: 28rpx;
	font-weight: 700;
	color: #145b88;
	margin-bottom: 18rpx;
}

.area-edit-card {
	margin-bottom: 24rpx;
	background: #f8fbff;
}

.area-edit-inline {
	margin-top: 18rpx;
}

.form-row {
	display: flex;
	gap: 16rpx;
	align-items: center;
}

.area-input {
	flex: 1;
	min-width: 0;
	height: 88rpx;
	padding: 0 24rpx;
	background: #f8fafc;
	border-radius: 24rpx;
	font-size: 28rpx;
	box-sizing: border-box;
}

.area-picker {
	min-width: 180rpx;
	height: 88rpx;
	padding: 0 24rpx;
	border-radius: 24rpx;
	background: #eef6fb;
	color: #145b88;
	font-size: 26rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	box-sizing: border-box;
}

.area-list {
	display: flex;
	flex-direction: column;
	gap: 24rpx;
}

.area-card {
	background: #ffffff;
	border-radius: 32rpx;
	padding: 26rpx;
	box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.06);
	border: 2rpx solid transparent;
}

.area-card.active {
	border-color: #4a9fe8;
	box-shadow: 0 12rpx 28rpx rgba(74, 159, 232, 0.14);
}

.area-card-top {
	display: flex;
	align-items: center;
}

.area-icon {
	font-size: 48rpx;
}

.area-name {
	margin-top: 18rpx;
	font-size: 32rpx;
	font-weight: 700;
	color: #1f2937;
}

.area-type {
	margin-top: 8rpx;
	font-size: 24rpx;
	color: #64748b;
}

.area-actions {
	margin-top: 18rpx;
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 20rpx;
}

.area-card.active {
	border-color: #4a9fe8;
	box-shadow: 0 12rpx 28rpx rgba(74, 159, 232, 0.14);
}

.area-hint {
	font-size: 26rpx;
	font-weight: 600;
	color: #3b82c4;
	flex: 1;
	min-width: 0;
}

.delete-btn {
	margin: 0;
	padding: 18rpx 26rpx;
	border-radius: 999rpx;
	background: #fef2f2;
	color: #dc2626;
	font-size: 26rpx;
	font-weight: 600;
	line-height: 1;
	flex-shrink: 0;
}

.delete-btn::after {
	border: none;
}