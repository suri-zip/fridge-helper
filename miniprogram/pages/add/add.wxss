.page-header {
  padding: 22rpx 12rpx 16rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #1f2937;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: #7b8492;
}

.action-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-card {
  display: flex;
  align-items: center;

  min-height: 132rpx;
  padding: 26rpx 28rpx;

  background: #ffffff;
  border-radius: 28rpx;
  box-sizing: border-box;

  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.05);
}

.action-card:active {
  transform: scale(0.985);
  opacity: 0.9;
}

.action-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 24rpx;

  display: flex;
  align-items: center;
  justify-content: center;

  background: #eef6ff;
  font-size: 44rpx;
  flex-shrink: 0;
}

.consume-card .action-icon {
  background: #fff3df;
}

.action-content {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.action-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.action-description {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #89919e;
}

.action-arrow {
  margin-left: 18rpx;
  font-size: 44rpx;
  color: #b5bdc8;
}

.coming-tag {
  padding: 5rpx 12rpx;
  border-radius: 10rpx;
  background: #eef3f8;
  color: #8995a4;
  font-size: 20rpx;
}

.disabled-card {
  background: #fbfcfd;
}