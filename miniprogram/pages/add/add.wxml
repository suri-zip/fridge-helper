<view class="container">
  <view class="page-header">
    <view class="page-title">记录冰箱变化</view>
    <view class="page-subtitle">
      今天往冰箱里放了什么，或者吃掉了什么？
    </view>
  </view>

  <view class="section-title">手动记录</view>

  <view class="action-grid">
    <view class="action-card stock-in-card" bindtap="goStockIn">
      <view class="action-icon">📥</view>
      <view class="action-content">
        <view class="action-title">食材入库</view>
        <view class="action-description">
          添加新购买的食材
        </view>
      </view>
      <view class="action-arrow">›</view>
    </view>

    <view class="action-card consume-card" bindtap="goConsume">
      <view class="action-icon">🍽️</view>
      <view class="action-content">
        <view class="action-title">记录消耗</view>
        <view class="action-description">
          扣除已经吃掉的食材
        </view>
      </view>
      <view class="action-arrow">›</view>
    </view>
  </view>

  <view class="section-title">智能工具</view>

  <view class="action-grid">
    <view class="action-card disabled-card" bindtap="goAiAssistant">
      <view class="action-icon">🐧</view>
      <view class="action-content">
        <view class="action-title-row">
          <view class="action-title">AI 助手</view>
          <view class="coming-tag">开发中</view>
        </view>
        <view class="action-description">
          用语音记录食材变化
        </view>
      </view>
      <view class="action-arrow">›</view>
    </view>

    <view class="action-card disabled-card" bindtap="goShoppingList">
      <view class="action-icon">🛒</view>
      <view class="action-content">
        <view class="action-title-row">
          <view class="action-title">购物清单</view>
          <view class="coming-tag">开发中</view>
        </view>
        <view class="action-description">
          整理需要补货的食材
        </view>
      </view>
      <view class="action-arrow">›</view>
    </view>
  </view>
</view>