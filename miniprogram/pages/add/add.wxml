<view class="container">
  <view class="section-title">添加食材</view>

  <view class="card form-card">
    <view class="field">
      <view class="label">食材名称</view>
      <input class="input" placeholder="比如：鸡蛋" data-field="name" bindinput="onInput" />
    </view>

    <view class="field">
        <view class="label">图标</view>
        <view class="emoji-grid">
          <block wx:for="{{emojiOptions}}" wx:key="*this">
            <view
              class="emoji-item {{form.emoji === item ? 'selected' : ''}}"
              data-emoji="{{item}}"
              bindtap="selectEmoji"
            >
              {{item}}
            </view>
          </block>
        </view>
      </view>


    <view class="field">
  <view class="label">数量</view>

  <view class="quantity-control">
    <view class="square-btn" bindtap="decreaseQuantity">－</view>

    <input
      class="quantity-input"
      type="number"
      value="{{form.quantity}}"
      data-field="quantity"
      bindinput="onInput"
    />

    <view class="square-btn" bindtap="increaseQuantity">＋</view>
  </view>
</view>

    <view class="field">
      <view class="label">单位</view>
      <picker range="{{unitOptions}}" bindchange="onUnitChange">
        <view class="picker">{{form.unit}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">存放位置</view>
      <picker range="{{storageOptions}}" range-key="label" value="{{storageIndex}}" bindchange="onStorageChange">
        <view class="picker">{{storageOptions[storageIndex] ? storageOptions[storageIndex].label : '请选择存放位置'}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="label">分类</view>
      <picker range="{{categoryOptions}}" bindchange="onCategoryChange">
        <view class="picker">{{form.category}}</view>
      </picker>
    </view>

    <view class="field">
  <view class="label">购买日期</view>
  <picker mode="date" value="{{form.purchaseDate}}" bindchange="onPurchaseDateChange">
    <view class="picker">{{form.purchaseDate || "请选择购买日期"}}</view>
  </picker>
</view>

<view class="field">
  <view class="label">保质期至</view>
  <picker mode="date" value="{{form.expireDate}}" bindchange="onExpireDateChange">
    <view class="picker">{{form.expireDate || "请选择保质期"}}</view>
  </picker>
</view>

    <button class="save-btn" bindtap="onSave">保存</button>
  </view>
</view>