<view class="container">
  <view class="hero card">
    <view class="penguin">🐧</view>
    <view>
      <view class="hello">{{greetingText}}</view>
      <view class="sub">{{heroSubText}}</view>
    </view>
  </view>

  <view class="search-box">
  <text class="search-icon">⌕</text>

  <input
    class="search-input"
    placeholder="搜索食材"
    value="{{keyword}}"
    bindinput="onSearchInput"
    bindconfirm="submitSearch"
    confirm-type="search"
  />

  <view
    wx:if="{{keyword}}"
    class="clear-search"
    bindtap="clearSearch"
  >
    ×
  </view>
</view>

  <view class="section-title">快过期（{{expiringItems.length}}）</view>
  <view class="expiring-list">
  <block wx:for="{{expiringItems}}" wx:key="id">
    <food-card item="{{item}}" bind:foodtap="onFoodTap" />
  </block>
</view>

  <view class="section-title">我的冰箱</view>
  <view class="area-grid">
    <block wx:for="{{fridgeAreas}}" wx:key="id">
      <view class="area-card" data-area-id="{{item.id}}" data-area-type="{{item.type}}" bindtap="goInventory">
        <view class="area-icon">{{item.icon}}</view>
        <view class="area-name">{{item.name}}</view>
        <view class="area-count">{{item.count}} 件</view>
      </view>
    </block>
  </view>

  <view class="section-title">最近更新</view>

<view class="card activity-card">
  <block wx:for="{{recentLogs}}" wx:key="_id">
    <view class="activity-item">
      <view class="activity-emoji">
        {{item.emoji || "🍽️"}}
      </view>

      <view class="activity-content">
        <view class="activity-text">
          <text class="activity-user">{{item.userName}}</text>
          <text> {{item.description}}</text>
        </view>

        <view class="activity-time">
          {{item.timeText}}
        </view>
      </view>
    </view>
  </block>

  <view wx:if="{{recentLogs.length === 0}}" class="empty-activity">
    暂时还没有更新记录
  </view>
</view>
</view>