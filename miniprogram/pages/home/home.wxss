.hero {
  background: #A7D8FF;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 36rpx;
}

.penguin {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #F8FAFC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.hello {
  font-size: 40rpx;
  font-weight: 800;
}

.sub {
  margin-top: 8rpx;
  font-size: 30rpx;
}

.search-box {
  height: 84rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.05);
}

.search-icon {
  color: #9ca3af;
  font-size: 34rpx;
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 28rpx;
  color: #1f2937;
}

.clear-search {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #eef2f6;
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}


.area-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.area-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.06);
}

.area-icon {
  font-size: 52rpx;
}

.area-name {
  margin-top: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.area-count {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.activity-card {
  padding: 12rpx 28rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-emoji {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #eaf5ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}

.activity-content {
  flex: 1;
}

.activity-text {
  font-size: 28rpx;
  color: #1f2937;
}

.activity-user {
  font-weight: 700;
}

.activity-time {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.empty-activity {
  padding: 48rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #9ca3af;
}